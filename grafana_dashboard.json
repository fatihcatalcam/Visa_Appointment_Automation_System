{
  "__inputs": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "title": "Active Workers",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          },
          "max": 50,
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "bot_active_workers",
          "legendFormat": "Active Workers"
        }
      ]
    },
    {
      "title": "CAPTCHA Rate (per 5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "spanNulls": true
          },
          "unit": "ops"
        }
      },
      "targets": [
        {
          "expr": "rate(bot_captchas_total[5m])",
          "legendFormat": "CAPTCHAs / 5m"
        }
      ]
    },
    {
      "title": "Login Attempts (Success vs Fail)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "increase(bot_login_attempts_total{status=\"success\"}[5m])",
          "legendFormat": "Success"
        },
        {
          "expr": "increase(bot_login_attempts_total{status=\"fail\"}[5m])",
          "legendFormat": "Fail"
        }
      ]
    },
    {
      "title": "Healthy Proxies",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "green", "value": 8 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "bot_healthy_proxies",
          "legendFormat": "Healthy Proxies"
        }
      ]
    },
    {
      "title": "Quarantined Accounts (Cooldown)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "bot_quarantined_accounts",
          "legendFormat": "Cooldown Accounts"
        }
      ]
    },
    {
      "title": "403 Forbidden Errors (Total)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#e74c3c", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 2,
            "pointSize": 4,
            "spanNulls": true
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "increase(bot_403_errors_total[5m])",
          "legendFormat": "403 Errors / 5m"
        }
      ]
    },
    {
      "title": "Page Load Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": true
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(bot_page_load_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(bot_page_load_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(bot_page_load_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Booking Success (Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#2ecc71", "mode": "fixed" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "bot_booking_success_total",
          "legendFormat": "Bookings"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["comp-bot", "bls-visa"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "BLS Visa Bot — Monitoring Dashboard",
  "uid": "comp-bot-main",
  "version": 1
}
